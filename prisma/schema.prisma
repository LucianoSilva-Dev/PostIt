generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PostIt {
  id           String   @id @default(uuid())
  text         String
  color        String
  textColor    String
  textureId    String
  textureColor String
  createdAt    DateTime @default(now())
  roomCode     String
}
